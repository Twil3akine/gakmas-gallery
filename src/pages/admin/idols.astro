---
import Layout from "../../layouts/Layout.astro";
import MasterManager from "../../components/MasterManager";
import { env } from "cloudflare:workers";

const db = env.DB;
const [idolsResult, genresResult] = await Promise.all([
  db.prepare("SELECT * FROM idols ORDER BY sort_order ASC").all(),
  db.prepare("SELECT * FROM genres ORDER BY id ASC").all(),
]);

const idols = idolsResult.results as { id: number; name: string }[];
const genres = genresResult.results as { id: number; name: string }[];
---

<Layout title="管理 - 学マスギャラリー">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-xl font-bold mb-6">マスタ管理</h1>
    <MasterManager idols={idols} genres={genres} client:load />
  </div>
</Layout>
